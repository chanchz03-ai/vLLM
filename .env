# ─────────────────────────────────────────────
#  LLM Streaming Skill-Up — Environment Config
# ─────────────────────────────────────────────

# Groq API Key — get yours at https://console.groq.com
GROQ_API_KEY=

# Groq API Base URL (don't change)
GROQ_API_BASE=https://api.groq.com/openai/v1

# ─── Models (Groq-supported) ───────────────────
# Fast model: for simple/short tasks
GROQ_MODEL_FAST=openai/gpt-oss-20b

# Capable model: for complex/long tasks
GROQ_MODEL_CAPABLE=openai/gpt-oss-20b

# Structured output model: good at JSON
GROQ_MODEL_STRUCTURED=openai/gpt-oss-20b

# ─── Server Config ─────────────────────────────
APP_HOST=127.0.0.1
APP_PORT=8000
APP_ENV=development       # development | production

# ─── Observability ─────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
ENABLE_METRICS=true

# ─── Streaming Config ──────────────────────────
STREAM_TIMEOUT_SECONDS=60
MAX_TOKENS_DEFAULT=1024
TEMPERATURE_DEFAULT=0.7